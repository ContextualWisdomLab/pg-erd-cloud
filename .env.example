# App metadata PostgreSQL (for this ERD SaaS itself)
POSTGRES_DB=erd
POSTGRES_USER=erd
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_PORT=54321

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Backend app secret (used for encrypting stored connection DSNs)
APP_SECRET=change-me-long-random

# Frontend -> backend
VITE_API_BASE_URL=http://localhost:8000

# Backend CORS
CORS_ORIGINS=http://localhost:5173

# Optional: OIDC (Casdoor) issuer; if set backend verifies JWTs
# OIDC_ISSUER=http://localhost:8002
# OIDC_AUDIENCE=erd-local
