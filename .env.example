# App metadata PostgreSQL (for this ERD SaaS itself)
POSTGRES_DB=erd
POSTGRES_USER=erd
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_PORT=54321

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Production edge port used by compose.prod.yaml (Traefik).
TRAEFIK_HTTP_PORT=8080

# Backend app secret (used for encrypting stored connection DSNs)
APP_SECRET=change-me-long-random

# Frontend -> backend
VITE_API_BASE_URL=http://localhost:8000

# Backend CORS
CORS_ORIGINS=http://localhost:5173

# Backend API rate limiting (applies to /api/*)
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60
# Set true only behind trusted proxy/ingress that sanitizes X-Forwarded-For.
API_RATE_LIMIT_TRUST_X_FORWARDED_FOR=false
API_RATE_LIMIT_MAX_KEYS=10000

# Optional: OIDC (Casdoor) issuer; if set backend verifies JWTs
# OIDC_ISSUER=http://localhost:8002
# OIDC_AUDIENCE=erd-local

# Optional: allowed JWT signing algorithms (comma-separated).
# Default is RS256.
# OIDC_ALGORITHMS=RS256
